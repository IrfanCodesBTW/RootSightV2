# AI APIs (REQUIRED unless DEMO_MODE=true)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Optional: Real integrations (leave blank for demo/offline mode)
DATADOG_API_KEY=
DATADOG_APP_KEY=
PAGERDUTY_INTEGRATION_KEY=
JIRA_API_TOKEN=
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# App config
DATABASE_URL=sqlite:///./rootsight.db
FAISS_INDEX_PATH=./storage/incident_index.faiss
LOG_LEVEL=INFO
DEMO_MODE=true
MAX_LOG_LINES=100
TIMELINE_MAX_TOKENS=3000
CORS_ORIGINS=http://localhost:3000
GEMINI_MODEL=models/gemini-flash-latest
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
API_ERROR_DETAIL_IN_RESPONSE=false
